# Win32-specific carve-outs (pragma-once is the house style; see CODE_CONVENTIONS):
#  reinterpret-cast / no-int-to-ptr are inherent to native Win32 -- HWND<->object
#  round-trips via GWLP_USERDATA + CREATESTRUCT, and the (HBRUSH)(COLOR_x+1) idiom.
#  pro-type-union-access -- SDK structs use anonymous unions we must write
#  (NOTIFYICONDATAW's uVersion/uTimeout for NIM_SETVERSION).
#  easily-swappable-parameters -- Win32 surfaces pass adjacent same-typed scalars
#  pervasively (message ids, handles, coords); fires across every wrapper.
#  implicit-bool-conversion -- bool<->BOOL is Win32's boolean (BOOL is just int);
#  the conversion is safe and intended, and fires on every BOOL-taking Win32 call.
Checks: >
  -*,
  bugprone-*,
  cppcoreguidelines-*,
  modernize-*,
  performance-*,
  portability-*,
  readability-*,
  -modernize-use-trailing-return-type,
  -readability-identifier-length,
  -cppcoreguidelines-avoid-magic-numbers,
  -readability-magic-numbers,
  -readability-braces-around-statements,
  -portability-avoid-pragma-once,
  -cppcoreguidelines-pro-type-reinterpret-cast,
  -performance-no-int-to-ptr,
  -cppcoreguidelines-pro-type-union-access,
  -bugprone-easily-swappable-parameters,
  -readability-implicit-bool-conversion
WarningsAsErrors: ''
HeaderFilterRegex: 'lib/.*'
CheckOptions:
  readability-implicit-bool-conversion.AllowPointerConditions: true
